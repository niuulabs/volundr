{
  "theme": "ice",
  "plugins": {
    "login": { "enabled": true, "order": 0 },
    "volundr": { "enabled": true, "order": 1 },
    "tyr": { "enabled": true, "order": 2 },
    "mimir": { "enabled": true, "order": 3 },
    "ravn": { "enabled": true, "order": 4 },
    "observatory": { "enabled": true, "order": 5 },
    "settings": { "enabled": true, "order": 6 }
  },
  "services": {
    "identity": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1" },
    "features": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1" },
    "tracker": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1" },
    "audit": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1" },
    "mimir": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1/mimir" },
    "observatory": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1/observatory" },
    "ravn": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1/ravn" },
    "forge": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1/forge" },
    "forge.pty": { "mode": "ws", "wsUrl": "ws://localhost:8080/api/v1/forge/pty/{sessionId}" },
    "forge.metrics": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1/forge/metrics" },
    "tyr": { "mode": "http", "baseUrl": "http://localhost:8080/api/v1/tyr" },
    "tyr.workflows": { "mode": "mock" }
  }
}
