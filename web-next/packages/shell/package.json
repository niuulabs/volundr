{
  "name": "@niuulabs/shell",
  "version": "0.0.1",
  "description": "Plugin shell — rail, topbar, subnav, content, footer. Host-agnostic.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "@tanstack/react-router": "^1.95.0",
    "react": "^19.0.0"
  },
  "dependencies": {
    "@niuulabs/plugin-sdk": "workspace:*",
    "@niuulabs/ui": "workspace:*",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@niuulabs/design-tokens": "workspace:*",
    "@tanstack/react-router": "^1.95.0",
    "@types/react": "^19.0.7",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "postcss-import": "^16.1.0",
    "react": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
