{
  "name": "@niuulabs/design-tokens",
  "version": "0.0.1",
  "description": "Niuu design tokens — CSS custom properties, fonts, ThemeProvider",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./tailwind.preset": "./tailwind.preset.ts",
    "./fonts/*": "./src/fonts/*"
  },
  "files": [
    "dist",
    "src/tokens.css",
    "src/fonts",
    "tailwind.preset.ts"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "react": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
