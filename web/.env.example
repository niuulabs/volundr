# OIDC Authentication (optional — leave empty to disable login flow)
# Works with any OIDC provider: Keycloak, Auth0, Okta, etc.
VITE_OIDC_AUTHORITY=https://keycloak.example.com/realms/volundr
VITE_OIDC_CLIENT_ID=volundr-ui
# VITE_OIDC_SCOPE=openid profile email
# VITE_OIDC_REDIRECT_URI=http://localhost:5174
# VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5174

# API target for vite dev proxy
# VITE_API_TARGET=http://localhost:8080
