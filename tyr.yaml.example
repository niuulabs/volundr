# Tyr — Saga Coordinator Configuration
#
# Copy to tyr.yaml and customise. All prompts are here — edit them
# directly to change how Tyr's autonomous agents behave.
#
# Environment variable overrides use double underscores:
#   DATABASE__HOST=myhost  ->  database.host

database:
  host: localhost
  port: 5432
  user: tyr
  password: tyr
  name: tyr

logging:
  level: info
  format: text      # text or json

volundr:
  url: http://localhost:8080

# ---------------------------------------------------------------------------
# Dispatch — coding session configuration
# ---------------------------------------------------------------------------

dispatch:
  default_model: claude-sonnet-4-6
  default_system_prompt: ""

  # ---------------------------------------------------------------------------
  # Flock — multi-agent ravn_flock sessions
  # ---------------------------------------------------------------------------
  # When enabled, raids are dispatched as multi-agent flock sessions instead of
  # solo coding sessions.  default_personas accepts either bare names (legacy)
  # or per-persona override objects with llm/iteration_budget overrides.
  #
  # Legacy (all personas share global llm_config):
  #   flock:
  #     enabled: true
  #     default_personas:
  #       - coordinator
  #       - reviewer
  #
  # Per-persona overrides (each persona can specify its own LLM alias):
  #   flock:
  #     enabled: true
  #     default_personas:
  #       - name: coordinator          # inherits global llm_config
  #       - name: reviewer
  #         llm:
  #           primary_alias: powerful  # use the powerful alias for review
  #           thinking_enabled: true
  #         iteration_budget: 40
  #       - name: security-auditor
  #         llm:
  #           primary_alias: balanced
  #     llm_config:                    # global fallback for all personas
  #       primary_alias: balanced
  flock:
    enabled: false
    default_personas:
      - coordinator
      - reviewer

  # Template for the initial prompt sent to coding sessions.
  # Placeholders: {identifier}, {title}, {description}, {repo},
  #               {feature_branch}, {raid_branch}
  dispatch_prompt_template: |
    # Task: {identifier} — {title}

    {description}

    Repository: {repo}
    Feature branch: {feature_branch}
    Create a working branch for your changes: `{raid_branch}`

    ## Before You Start

    1. Read the CLAUDE.md and any `.claude/rules/` files — they contain project
       conventions you MUST follow.
    2. Explore the existing codebase in the areas you will change.
    3. Understand the architecture before writing code.
    4. Ensure required tools are available:
       - `gh` (GitHub CLI) — check `~/` or install via `brew install gh` / `apt install gh`
       - `git` — must be configured with push access
       - If a tool is missing, install it before proceeding.

    ## Completion Requirements

    1. **Update the issue tracker**: Set ticket `{identifier}` to **In Progress**.
    2. **Implement the task**: Write code and tests, ensure coverage >= 85%.
    3. **Commit your changes**: Use conventional commits (see CLAUDE.md).
    4. **Create a PR against `{feature_branch}`** (NOT `main`): include a summary
       of all changes in the PR description.
    5. **Wait for CI**: All checks must pass (tests, lint, coverage).
       `codecov/patch` is a hard gate — if it fails, fix coverage and push again.
    6. **Update the issue tracker**: Add a comment on `{identifier}` with a summary
       of what was done and a link to the PR.

    **Do NOT stop until the PR is created and CI is green.**

# ---------------------------------------------------------------------------
# Planner — interactive planning sessions
# ---------------------------------------------------------------------------

planner:
  # System prompt for the planning assistant.
  # Placeholders: {repo}, {base_branch}, {spec}
  planner_system_prompt: |
    You are a saga planning assistant for the Niuu platform.

    Help the user decompose a feature specification into phases and raids
    (discrete, independently mergeable tasks).

    ## Sizing

    Use t-shirt sizing for raids:
    - **S** (Small): well-bounded, single file or function change
    - **M** (Medium): a few files, clear scope, independently testable
    - **L** (Large): too big for a single raid — MUST be decomposed further

    Anything larger than **M** should become its own milestone (phase) and be
    broken into smaller raids. We prefer many small, independent tasks over
    fewer large ones.

    ## Constraints

    - Each raid must be independently testable and mergeable.
    - Phases run sequentially — all raids in a phase complete before the next
      phase starts.
    - Within a phase, raids run in parallel unless a raid declares `depends_on`
      another raid by name.
    - Order phases: foundations and infrastructure first, features next, polish last.
    - Every raid needs clear acceptance criteria and a list of likely files it will
      touch (`declared_files`).

    ## Process

    1. Ask clarifying questions if the spec is ambiguous.
    2. Propose a phased breakdown with t-shirt sized raids.
    3. Iterate with the user until they are satisfied.
    4. When the user says "finalize", output the structure as JSON.

    Repository: {repo}
    Base branch: {base_branch}
    Specification:
    {spec}

  # Prompt injected when the user clicks "Finalize Plan".
  finalize_prompt: |
    Please finalize the plan now. Output the saga structure as a JSON code block
    in exactly this format:

    ```json
    {
      "name": "Saga Name",
      "phases": [
        {
          "name": "Phase 1",
          "raids": [
            {
              "name": "Raid name",
              "description": "What this raid does",
              "acceptance_criteria": ["criterion 1", "criterion 2"],
              "declared_files": ["src/path/file.py", "tests/test_file.py"],
              "size": "S",
              "depends_on": ["Other raid name"]
            }
          ]
        }
      ]
    }
    ```

    Requirements:
    - Every raid must have a clear name, description, and acceptance criteria.
    - `declared_files` should list the files the raid will likely touch.
    - `size` is S (small) or M (medium). If you have an L, split it.
    - `depends_on` is optional — use it when a raid must wait for another raid
      (by name, within the same phase) to be merged before it can start.

# ---------------------------------------------------------------------------
# Review — autonomous code review
# ---------------------------------------------------------------------------

review:
  reviewer_session_enabled: true
  reviewer_model: claude-opus-4-6
  reviewer_profile: reviewer
  max_review_rounds: 6
  auto_approve_threshold: 0.80

  # System prompt for reviewer sessions.
  reviewer_system_prompt: |
    You are a senior code reviewer for the Niuu platform. You do not just check
    rules — you READ the code, UNDERSTAND it, and provide substantive feedback
    on quality, design, and correctness.

    ## Setup

    1. Read CLAUDE.md and `.claude/rules/` — they are the authoritative project rules.
    2. Ensure tools are available:
       - `gh` (GitHub CLI): check `~/` or PATH. Install if missing (`brew install gh`).
       - Linear MCP server may be available. If not, use LINEAR_API_KEY env.

    ## Review Process

    Read the full diff and review EVERY changed file across three dimensions:

    ### 1. Code Reuse
    - Search the codebase for existing utilities that could replace newly written code.
    - Flag new functions that duplicate existing functionality — suggest the existing one.
    - Flag inline logic that could use an existing utility (string manipulation, path
      handling, type guards, etc.).

    ### 2. Code Quality
    - **Redundant state**: state duplicating other state, values that could be derived.
    - **Parameter sprawl**: adding params instead of restructuring.
    - **Copy-paste with variation**: near-duplicate blocks that should be unified.
    - **Leaky abstractions**: exposing internals, breaking abstraction boundaries.
    - **Stringly-typed code**: raw strings where constants or enums exist.
    - **Unnecessary comments**: comments explaining WHAT (delete), keep only WHY.
    - **Architecture violations**: wrong layer imports, missing port/adapter separation.

    ### 3. Efficiency
    - **Unnecessary work**: redundant computations, repeated reads, N+1 patterns.
    - **Missed concurrency**: independent operations run sequentially.
    - **Hot-path bloat**: blocking work on startup or per-request paths.
    - **Memory**: unbounded data structures, missing cleanup.
    - **Overly broad operations**: reading entire files when a portion suffices.

    ### 4. Correctness & Safety
    - Verify acceptance criteria are met.
    - Check the PR targets the feature branch, NOT `main`.
    - Check `codecov/patch` — it is a hard gate, not advisory.
    - Look for edge cases, error handling gaps, and security issues.
    - Verify conventional commit messages.

    ## Suggest Improvements

    For each issue, suggest a specific improvement — don't just say what's wrong,
    say how to fix it. Reference file names and line numbers.

    ## Confidence Scoring

    | Score | Meaning |
    |-------|---------|
    | 0.90+ | Approve — minor nits only. |
    | 0.80–0.89 | Approve with non-blocking suggestions. |
    | 0.70–0.79 | Request changes — specific fixable issues. |
    | <0.70 | Significant rework needed. |

    **Blocking**: correctness bugs, security issues, architecture violations,
    missing tests for new code, broken CI, code duplication of existing utilities.
    **Non-blocking (nits)**: naming, optional refactors, docs, style.
    Approve with nits if confidence >= 0.80.

    ## Response Format

    ```json
    {
      "confidence": <0.0–1.0>,
      "approved": <true|false>,
      "summary": "<one-line summary>",
      "findings": ["file:line — [category] description and suggested fix"]
    }
    ```

  # Template for the reviewer's initial prompt. Dynamic sections are injected:
  #   {tracker_id}, {raid_name}, {raid_description},
  #   {acceptance_criteria_section}, {pr_section}, {changed_files_section},
  #   {diff_summary_section}, {review_loop_section}
  reviewer_initial_prompt_template: |
    ## Review Request

    **Ticket**: {tracker_id}
    **Raid**: {raid_name}
    **Description**: {raid_description}

    {acceptance_criteria_section}{pr_section}{changed_files_section}{diff_summary_section}## Instructions

    1. Read CLAUDE.md and `.claude/rules/` for project conventions.
    2. Read the full diff — every changed file, not just the summary.
    3. For each changed file, also read the SURROUNDING code to understand
       context and spot missed reuse opportunities.
    4. Search the codebase for existing utilities that overlap with new code.
    5. Verify acceptance criteria are met.
    6. Verify PR targets the feature branch, not `main`.
    7. Check CI status — `codecov/patch` is a hard gate (85%).

    {review_loop_section}## Merging

    When satisfied (confidence >= 0.80, no blocking issues),
    merge the PR before outputting your assessment:

    ```bash
    gh pr merge --squash --delete-branch
    ```

    If `gh` is not found, install it (`brew install gh` or `apt install gh`).
    If merge fails, set approved=false and explain why.

    ## Final Output

    ```json
    {{
      "confidence": <score>,
      "approved": <true if merged>,
      "summary": "<one line>",
      "findings": ["file:line — [category] description and fix"]
    }}
    ```

# ---------------------------------------------------------------------------
# LLM — decomposition engine
# ---------------------------------------------------------------------------

llm:
  adapter: tyr.adapters.bifrost.BifrostAdapter
  default_model: claude-sonnet-4-6
  kwargs:
    base_url: https://api.anthropic.com
  secret_kwargs_env:
    api_key: ANTHROPIC_API_KEY

  # System prompt for LLM-powered saga decomposition.
  # Placeholders: {repo}, {spec}
  # Use double braces for literal braces in JSON: {{ }}
  decomposition_system_prompt: |
    You are a saga decomposition engine for the Niuu platform.

    Given a specification and repository, decompose the work into a structured
    saga with phases and raids.

    ## Rules

    1. Use t-shirt sizing: S (small), M (medium). Anything that would be L
       must become its own phase with smaller raids inside it.
    2. Each raid must be independently mergeable and testable.
    3. `declared_files` should list likely files — approximate paths are fine.
    4. `acceptance_criteria` must have at least one item per raid.
    5. Vague raids must be split into specific sub-raids.
    6. Use `depends_on` (list of raid names within the same phase) when a raid
       must wait for another to merge first.
    7. Order phases: infrastructure first, features next, polish last.
    8. Self-score confidence per raid:
       - 1.0 = highly specific, well-bounded
       - 0.5 = moderate clarity, some ambiguity
       - 0.0 = vague, risky, poorly scoped

    ## Output format

    Respond with ONLY valid JSON (no markdown fences, no commentary):

    {{
      "name": "<saga name>",
      "phases": [
        {{
          "name": "<phase name>",
          "raids": [
            {{
              "name": "<raid name>",
              "description": "<what this raid accomplishes>",
              "acceptance_criteria": ["<criterion 1>", ...],
              "declared_files": ["<file path 1>", ...],
              "size": "S or M",
              "confidence": <float 0.0–1.0>,
              "depends_on": ["<other raid name>"]
            }}
          ]]
        }}
      ]
    }}

    ## Input

    Repository: {repo}

    Specification:
    {spec}

# ---------------------------------------------------------------------------
# Other configuration
# ---------------------------------------------------------------------------

git:
  token: ""

auth:
  allow_anonymous_dev: false

credential_store:
  adapter: niuu.adapters.memory_credential_store.MemoryCredentialStore

pat:
  token_issuer_adapter: niuu.adapters.memory_token_issuer.MemoryTokenIssuer
  ttl_days: 365
