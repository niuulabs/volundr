#!/bin/bash
set -e

# svc - CLI wrapper for the Skuld service manager API
# Usage: svc {start|stop|list|logs|status|restart} ...

API="http://localhost:8081/api/services"

usage() {
    cat <<'EOF'
Usage: svc <command> [options]

Commands:
  start <name> --cmd <command> --port <port> [--cwd <dir>] [--path <path>]
      Start a new service

  stop <name>
      Stop a running service

  list
      List all services

  status <name>
      Get status of a specific service

  logs <name> [lines]
      View service logs (default: last 100 lines)

  restart <name>
      Restart a service

  postgres
      Show PostgreSQL connection info

Examples:
  svc start api --cmd "uvicorn main:app --port 9001" --port 9001
  svc start frontend --cmd "npm run dev -- --port 9002" --port 9002
  svc list
  svc logs api
  svc stop api
EOF
}

cmd_start() {
    local name="$1"
    shift

    if [ -z "$name" ]; then
        echo "Error: service name required"
        echo "Usage: svc start <name> --cmd <command> --port <port>"
        exit 1
    fi

    local cmd="" port="" cwd="" path=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --cmd) cmd="$2"; shift 2 ;;
            --port) port="$2"; shift 2 ;;
            --cwd) cwd="$2"; shift 2 ;;
            --path) path="$2"; shift 2 ;;
            *) echo "Unknown option: $1"; exit 1 ;;
        esac
    done

    if [ -z "$cmd" ] || [ -z "$port" ]; then
        echo "Error: --cmd and --port are required"
        echo "Usage: svc start <name> --cmd <command> --port <port>"
        exit 1
    fi

    local json
    json=$(cat <<ENDJSON
{"name":"$name","command":"$cmd","port":$port,"cwd":"$cwd","path":"$path"}
ENDJSON
)

    curl -sX POST "$API" \
        -H "Content-Type: application/json" \
        -d "$json" | jq .
}

cmd_stop() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Error: service name required"
        exit 1
    fi
    curl -sX DELETE "$API/$name" | jq .
}

cmd_list() {
    curl -s "$API" | jq .
}

cmd_status() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Error: service name required"
        exit 1
    fi
    curl -s "$API/$name" | jq .
}

cmd_logs() {
    local name="$1"
    local lines="${2:-100}"
    if [ -z "$name" ]; then
        echo "Error: service name required"
        exit 1
    fi
    curl -s "$API/$name/logs?lines=$lines" | jq -r '.logs // .detail // "No logs available"'
}

cmd_restart() {
    local name="$1"
    if [ -z "$name" ]; then
        echo "Error: service name required"
        exit 1
    fi
    curl -sX POST "$API/$name/restart" | jq .
}

cmd_postgres() {
    echo "PostgreSQL is available at:"
    echo "  Host:     127.0.0.1"
    echo "  Port:     5432"
    echo "  Socket:   /run/postgresql"
    echo "  Auth:     trust (no password)"
    echo ""
    echo "Connection strings:"
    echo "  postgresql://127.0.0.1:5432/postgres"
    echo "  postgresql:///postgres?host=/run/postgresql"
    echo ""
    echo "CLI:"
    echo "  psql -h 127.0.0.1 -p 5432 -U devrunner postgres"
}

case "${1:-}" in
    start)   shift; cmd_start "$@" ;;
    stop)    shift; cmd_stop "$@" ;;
    list)    cmd_list ;;
    status)  shift; cmd_status "$@" ;;
    logs)    shift; cmd_logs "$@" ;;
    restart) shift; cmd_restart "$@" ;;
    postgres) cmd_postgres ;;
    -h|--help|help|"") usage ;;
    *) echo "Unknown command: $1"; usage; exit 1 ;;
esac
